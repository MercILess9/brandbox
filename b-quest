<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>B-QUEST | Mission Control</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="config.js"></script>
    <script src="system.js"></script>

    <style>
        :root { --primary-color: #2d4739; --accent-color: #bdc432; }
        body { background-color: #f8f9fa; padding-bottom: 50px; }
        .navbar-brand { fw-bold; color: var(--primary-color) !important; }
        .card-quest { transition: transform 0.2s; border-left: 5px solid #ccc; }
        .card-quest:hover { transform: translateY(-3px); }
        .status-done { border-left-color: #198754; }
        .status-progress { border-left-color: #ffc107; }
        .deadline-badge { font-size: 0.75rem; padding: 5px 10px; border-radius: 20px; }
        #loadingOverlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255,255,255,0.8); z-index: 9999;
            display: flex; justify-content: center; align-items: center;
        }
    </style>
</head>
<body>

<div id="loadingOverlay" class="d-none">
    <div class="spinner-border text-primary" role="status"></div>
    <span class="ms-2">กำลังโหลดข้อมูล...</span>
</div>

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand" href="#">B-QUEST</a>
        <div class="d-flex align-items-center">
            <span class="me-3 d-none d-md-inline" id="user-display">สวัสดี, ...</span>
            <button class="btn btn-outline-danger btn-sm" onclick="BQuest.logout()">Logout</button>
        </div>
    </div>
</nav>

<div class="container">
    <div class="card p-3 mb-4 border-0 shadow-sm">
        <div class="row g-2">
            <div class="col-md-4">
                <input type="text" id="searchInput" class="form-control" placeholder="ค้นหาชื่อลูกค้า, ชื่องาน...">
            </div>
            <div class="col-md-3">
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด (ทุกสถานะ)</option>
                    <option value="Pending">Pending</option>
                    <option value="On Progress">On Progress</option>
                    <option value="Done">Done</option>
                </select>
            </div>
            <div class="col-md-3">
                <input type="date" id="filterDate" class="form-control" title="Filter by Publish Date">
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" onclick="fetchQuests()">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
            </div>
        </div>
    </div>

    <div class="row mb-3 text-center">
        <div class="col-4"><div class="card p-2 bg-white border-0 shadow-sm"><strong>ทั้งหมด</strong><div id="count-all">0</div></div></div>
        <div class="col-4"><div class="card p-2 bg-warning-subtle border-0 shadow-sm text-warning-emphasis"><strong>ทำอยู่</strong><div id="count-progress">0</div></div></div>
        <div class="col-4"><div class="card p-2 bg-success-subtle border-0 shadow-sm text-success-emphasis"><strong>เสร็จแล้ว</strong><div id="count-done">0</div></div></div>
    </div>

    <div id="taskContainer">
        </div>
</div>

<div class="modal fade" id="questModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">รายละเอียดภารกิจ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
                </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    let allQuests = [];

    // 1. โหลดข้อมูลเมื่อเปิดหน้า
    async function initPage() {
        // ดึงชื่อ User จาก Profile (ใน system.js)
        const { data: { session } } = await supabaseClient.auth.getSession();
        if (session) {
            const profile = await BQuest.getProfile(session.user.id);
            if (profile) BQuest.setText("user-display", `สวัสดี, ${profile.nick_name || 'นักล่าเควส'}`);
        }
        fetchQuests();
    }

    // 2. ดึงข้อมูลจาก Supabase
    async function fetchQuests() {
        document.getElementById('loadingOverlay').classList.remove('d-none');
        
        const { data, error } = await supabaseClient
            .from('tasks') // มั่นใจว่าชื่อตารางตรงกับที่พี่ Import
            .select('*')
            .order('publish_date', { ascending: false });

        document.getElementById('loadingOverlay').classList.add('d-none');

        if (error) {
            BQuest.notify("โหลดข้อมูลล้มเหลว", "error");
            return;
        }

        allQuests = data;
        applyFilters();
    }

    // 3. ระบบ Filter
    function applyFilters() {
        const searchTerm = document.getElementById("searchInput").value.toLowerCase();
        const statusTerm = document.getElementById("filterStatus").value;
        const dateTerm = document.getElementById("filterDate").value;

        const filtered = allQuests.filter(q => {
            const matchSearch = (q.task_name?.toLowerCase().includes(searchTerm)) || 
                                (q.account_name?.toLowerCase().includes(searchTerm));
            const matchStatus = statusTerm === "" || q.designer_status === statusTerm || q.creative_status === statusTerm;
            const matchDate = dateTerm === "" || q.publish_date === dateTerm;

            return matchSearch && matchStatus && matchDate;
        });

        renderCards(filtered);
        updateStats(filtered);
    }

    // 4. วาดการ์ดใบๆ
    function renderCards(data) {
        const container = document.getElementById("taskContainer");
        container.innerHTML = "";

        if (data.length === 0) {
            container.innerHTML = `<div class="text-center p-5 text-muted">ไม่พบข้อมูลภารกิจ</div>`;
            return;
        }

        data.forEach(task => {
            const card = document.createElement("div");
            card.className = `card card-quest shadow-sm mb-3 border-0 ${task.designer_status === 'Done' ? 'status-done' : 'status-progress'}`;
            
            card.innerHTML = `
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6" onclick="showDetail('${task.id}')" style="cursor:pointer;">
                            <h5 class="mb-1 text-dark">${task.task_name}</h5>
                            <p class="text-muted small mb-0">${task.account_name} | ${task.opportunity_name}</p>
                        </div>
                        <div class="col-md-4 text-md-center my-2 my-md-0">
                            <span class="deadline-badge bg-primary-subtle text-primary">
                                <i class="bi bi-calendar-event"></i> D: ${task.designer_deadline || '-'}
                            </span>
                            <span class="deadline-badge bg-info-subtle text-info ms-1">
                                <i class="bi bi-calendar-event"></i> C: ${task.creative_deadline || '-'}
                            </span>
                        </div>
                        <div class="col-md-2 text-end">
                            <button class="btn btn-sm btn-light border" onclick="showDetail('${task.id}')">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `;
            container.appendChild(card);
        });
    }

    // 5. ดูรายละเอียด (Modal)
    function showDetail(id) {
        const task = allQuests.find(q => q.id === id);
        const modalBody = document.getElementById("modalBody");
        
        modalBody.innerHTML = `
            <div class="row g-3">
                <div class="col-md-12"><strong>รายละเอียดงาน:</strong><p class="border p-2 bg-light rounded">${task.detail || '-'}</p></div>
                <div class="col-md-6"><strong>Link งาน:</strong><br><a href="${task.link}" target="_blank" class="text-truncate d-block">${task.link || '-'}</a></div>
                <div class="col-md-6"><strong>Owner:</strong> ${task.owner}</div>
                <hr>
                <div class="col-md-6">
                    <h6>Designer</h6>
                    <p class="mb-1">สถานะ: <span class="badge bg-secondary">${task.designer_status}</span></p>
                    <p class="small">ผู้รับผิดชอบ: ${task.designer_assign || '-'}</p>
                </div>
                <div class="col-md-6">
                    <h6>Creative</h6>
                    <p class="mb-1">สถานะ: <span class="badge bg-secondary">${task.creative_status}</span></p>
                    <p class="small">ผู้รับผิดชอบ: ${task.creative_assign || '-'}</p>
                </div>
            </div>
        `;
        const myModal = new bootstrap.Modal(document.getElementById('questModal'));
        myModal.show();
    }

    function updateStats(data) {
        document.getElementById("count-all").innerText = data.length;
        document.getElementById("count-progress").innerText = data.filter(q => q.designer_status !== 'Done').length;
        document.getElementById("count-done").innerText = data.filter(q => q.designer_status === 'Done').length;
    }

    // Event Listeners
    document.getElementById("searchInput").addEventListener("input", applyFilters);
    document.getElementById("filterStatus").addEventListener("change", applyFilters);
    document.getElementById("filterDate").addEventListener("change", applyFilters);

    // เริ่มทำงาน
    initPage();

</script>

</body>
</html>